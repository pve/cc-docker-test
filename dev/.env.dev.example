# Copy to .env.dev and fill in values before running setup-dev.sh
# Never commit .env.dev to git.

# GitHub Personal Access Token
# Required scopes: repo, packages:write, read:packages
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Git identity (used for commits made inside cc-dev)
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=you@example.com

# Your local machine's SSH public key — paste the contents of ~/.ssh/id_ed25519.pub (or id_rsa.pub)
# This is written to /root/.ssh/authorized_keys inside cc-dev so you can SSH straight in.
SSH_AUTHORIZED_KEY=ssh-ed25519 AAAA...
